{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/task-graph.json",
  "title": "AI Game Studio Agent Task Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "tasks"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "agent",
          "priority",
          "depends_on",
          "input",
          "output",
          "validation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "agent": {
            "type": "string",
            "enum": [
              "game-designer",
              "cocos-programmer",
              "artist",
              "qa"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "input": {
            "type": "string",
            "minLength": 1
          },
          "output": {
            "type": "string",
            "minLength": 1
          },
          "validation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
