        "game-design"
      ],
      "allowed_agents": [
        "game-designer"
      ],
      "external": false,
      "execution_enabled": false
    },
    {
      "id": "blueprint-system-planner",
      "description": "Transform Blueprint system metadata into planning requirements only.",
      "capabilities": [
        "system-implementation-plan"
      ],
      "allowed_agents": [
        "cocos-programmer"
      ],
      "external": false,
      "execution_enabled": false
    },
    {
      "id": "asset-requirement-catalog",
      "description": "Organize Blueprint asset names into a non-executable requirement catalog.",
      "capabilities": [
        "asset-requirements"
      ],
      "allowed_agents": [
        "artist"
      ],
      "external": false,
      "execution_enabled": false
    },
    {
      "id": "validation-checklist-builder",
      "description": "Build a static validation checklist from planning metadata.",
      "capabilities": [
        "validation-checklist"
      ],
      "allowed_agents": [
        "qa"
      ],
      "external": false,
      "execution_enabled": false
    }
  ]
