{
  "schema_version": "1.0.0",
  "mode": "prototype-metadata-only",
  "capabilities": [
    {
      "id": "game-design",
      "description": "Produce a game design specification from Blueprint design data."
    },
    {
      "id": "system-implementation-plan",
      "description": "Produce implementation planning without generating game code."
    },
    {
      "id": "asset-requirements",
      "description": "Produce a resource requirement list without creating assets."
    },
    {
      "id": "validation-checklist",
      "description": "Produce a validation checklist from prior planning artifacts."
    }
  ],
  "tools": [
    {
      "id": "blueprint-design-reader",
      "description": "Read design metadata already embedded in a Task Graph input.",
