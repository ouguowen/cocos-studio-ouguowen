{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/agent-capability.json",
  "title": "AI Game Studio Agent Capability Binding",
  "type": "object",
  "required": [
    "id",
    "capabilities",
    "tool_ids",
    "execution_enabled"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tool_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "execution_enabled": {
      "type": "boolean",
      "const": false
    }
  }
}
