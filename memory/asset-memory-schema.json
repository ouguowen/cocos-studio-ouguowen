{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/asset-memory.json",
  "title": "Asset Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "asset_id",
    "asset_type",
    "related_assets",
    "version",
    "description",
    "usage_context"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "asset_type": {
      "type": "string",
      "minLength": 1
    },
    "related_assets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "usage_context": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
