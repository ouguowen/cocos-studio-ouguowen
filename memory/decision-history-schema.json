{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/decision-history.json",
  "title": "Decision History",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "task_id",
    "decision",
    "reason",
    "related_agents",
    "timestamp"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "related_agents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
