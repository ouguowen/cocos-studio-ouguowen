{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/project-memory.json",
  "title": "Project Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "project_name",
    "game_type",
    "genre",
    "platform",
    "design_rules",
    "technical_constraints",
    "art_direction",
    "audio_direction",
    "ui_direction"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "game_type": {
      "type": "string",
      "minLength": 1
    },
    "genre": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "design_rules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "technical_constraints": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "art_direction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style",
        "color",
        "lighting"
      ],
      "properties": {
        "style": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": "string",
          "minLength": 1
        },
        "lighting": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "audio_direction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style",
        "mood"
      ],
      "properties": {
        "style": {
          "type": "string",
          "minLength": 1
        },
        "mood": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ui_direction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style",
        "color",
        "layout"
      ],
      "properties": {
        "style": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": "string",
          "minLength": 1
        },
        "layout": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
