{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/validation-report.json",
  "title": "Validation Agent Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "score",
    "issues",
    "warnings",
    "recommendations",
    "execution_enabled"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARNING",
        "FAILED"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "recommendations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "execution_enabled": {
      "const": false
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "category",
        "severity",
        "message",
        "observed",
        "expected"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "completeness",
            "quality"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "observed": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
