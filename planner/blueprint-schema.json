{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/game-blueprint.json",
  "title": "AI Game Studio Game Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "design",
    "systems",
    "assets",
    "agents"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "genre",
        "engine",
        "platform"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "genre": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string",
          "const": "Cocos Creator"
        },
        "platform": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "theme",
        "camera",
        "gameplay_loop"
      ],
      "properties": {
        "theme": {
          "type": "string",
          "minLength": 1
        },
        "camera": {
          "type": "string",
          "minLength": 1
        },
        "gameplay_loop": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "characters",
        "scenes",
        "ui",
        "audio"
      ],
      "properties": {
        "characters": {
          "$ref": "#/$defs/stringList"
        },
        "scenes": {
          "$ref": "#/$defs/stringList"
        },
        "ui": {
          "$ref": "#/$defs/stringList"
        },
        "audio": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "responsibility"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1
          },
          "responsibility": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
