{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/provider-schema.json",
  "title": "Capability Provider",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "type",
    "capabilities",
    "adapter",
    "execution_enabled",
    "priority",
    "speed",
    "quality"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "image",
        "engine"
      ]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adapter": {
      "type": "string",
      "minLength": 1
    },
    "execution_enabled": {
      "const": false
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "speed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "quality": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    }
  }
}
