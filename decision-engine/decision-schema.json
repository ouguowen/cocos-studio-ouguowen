{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/autonomous-decision.json",
  "title": "Autonomous Next Action Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "input_context",
    "candidate_actions",
    "priority_score",
    "selected_action",
    "reason",
    "confidence",
    "execution_enabled"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^decision-[0-9]{4,}$"
    },
    "input_context": {
      "$ref": "#/$defs/inputContext"
    },
    "candidate_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "priority_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "selected_action": {
      "$ref": "#/$defs/action"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "execution_enabled": {
      "const": false
    }
  },
  "$defs": {
    "inputContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "project_phase",
        "project_status",
        "completion_rate",
        "current_issues",
        "feedback_capabilities",
        "historical_decision_count",
        "memory_asset_count"
      ],
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "project_phase": {
          "type": "string",
          "minLength": 1
        },
        "project_status": {
          "type": "string",
          "enum": [
            "on-track",
            "at-risk",
            "blocked"
          ]
        },
        "completion_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "current_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "severity",
              "description"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "feedback_capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "historical_decision_count": {
          "type": "integer",
          "minimum": 0
        },
        "memory_asset_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "action",
        "agent",
        "capability",
        "status",
        "base_priority",
        "blocked_by",
        "risk_level",
        "feedback_score",
        "memory_relevance",
        "priority_score"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "capability": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "in-progress",
            "pending",
            "blocked"
          ]
        },
        "base_priority": {
          "type": "integer",
          "minimum": 1
        },
        "blocked_by": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "feedback_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "memory_relevance": {
          "type": "integer",
          "minimum": 0
        },
        "priority_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  }
}
