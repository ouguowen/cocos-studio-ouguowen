{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cocos-studio-ouguowen.local/schemas/project-intelligence.json",
  "title": "Project Intelligence State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "execution_enabled",
    "project_id",
    "game_type",
    "engine",
    "phase",
    "systems",
    "assets",
    "agents",
    "tasks",
    "issues",
    "history"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "const": "project-intelligence-metadata-only"
    },
    "execution_enabled": {
      "const": false
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "game_type": {
      "type": "string",
      "minLength": 1
    },
    "engine": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "concept",
        "planning",
        "production",
        "validation",
        "release"
      ]
    },
    "systems": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/system"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agent"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/history"
      }
    }
  },
  "$defs": {
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "in-progress",
            "pending",
            "blocked"
          ]
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "status",
        "provider"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ready",
            "specified",
            "pending",
            "blocked"
          ]
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "assigned_tasks",
        "execution_enabled"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "registered",
            "unavailable"
          ]
        },
        "assigned_tasks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "execution_enabled": {
          "const": false
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "agent",
        "depends_on",
        "priority"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "in-progress",
            "pending",
            "blocked"
          ]
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "status",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "resolved"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "task_id",
        "decision",
        "reason",
        "related_agents",
        "timestamp"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "related_agents": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
